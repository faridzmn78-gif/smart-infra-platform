                    "group": "grafana-postgresql-datasource",
                    "kind": "DataQuery",
                    "spec": {
                      "dataset": "smart_infra",
                      "editorMode": "code",
                      "format": "table",
                      "rawQuery": true,
                      "rawSql": "SELECT\r\nCASE\r\n    WHEN COUNT(*) = 0 THEN 100\r\n    ELSE\r\n        ROUND(\r\n            (\r\n                SUM(\r\n                    CASE\r\n                        WHEN cpu_status = 'normal'\r\n                         AND ram_status = 'normal'\r\n                         AND disk_status = 'normal'\r\n                        THEN 1\r\n                        ELSE 0\r\n                    END\r\n                )::numeric\r\n                /\r\n                COUNT(*)\r\n            ) * 100\r\n        )\r\nEND AS value\r\nFROM anomalies a\r\nJOIN metrics m\r\n    ON a.metric_id = m.id\r\nWHERE m.created_at >= NOW() - INTERVAL '1 hour';",
                      "sql": {
                        "columns": [
